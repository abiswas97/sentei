#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Identity guard: a test-helper config leak once poisoned 100+ commits with a
# placeholder identity (Test <t@t.com>, displayed on GitHub as a stranger's
# account). Refuse to commit under anything but the repo's real identity.
EXPECTED_EMAIL="avishek.biswas.1997@gmail.com"
actual_email="$(git config user.email || true)"
if [ "$actual_email" != "$EXPECTED_EMAIL" ]; then
	echo "ERROR: git identity is '$actual_email', expected '$EXPECTED_EMAIL'."
	echo "       A test or tool has likely leaked config into this repo."
	echo "       Fix: git config user.email $EXPECTED_EMAIL && git config user.name Avi"
	exit 1
fi

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$staged_go_files" ]; then
	exit 0
fi

if ! command -v golangci-lint &>/dev/null; then
	echo "ERROR: golangci-lint not found. Install: brew install golangci-lint"
	exit 1
fi

echo "Running golangci-lint..."
cd "$REPO_ROOT"
golangci-lint run ./...
